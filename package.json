{
  "name": "anima",
  "version": "0.1.0",
  "description": "Anima — a desktop control panel for AI personalities in Claude Code.",
  "author": "Anima",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"node scripts/launch.cjs --dev\"",
    "build": "vite build",
    "start": "node scripts/launch.cjs",
    "preview": "npm run build && node scripts/launch.cjs",
    "icons": "node scripts/make-icons.cjs",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.anima.app",
    "productName": "Anima",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.png",
      "!**/*.map"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Anima"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "jimp": "^0.22.12",
    "png-to-ico": "^3.0.1",
    "vite": "^5.4.2"
  },
  "dependencies": {
    "msedge-tts": "^2.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
